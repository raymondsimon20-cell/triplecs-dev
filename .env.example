# ─── Schwab API ──────────────────────────────────────────────────────────────
# From your Schwab Developer Portal app registration
SCHWAB_CLIENT_ID=your_schwab_client_id
SCHWAB_CLIENT_SECRET=your_schwab_client_secret

# Must match the callback URL registered in your Schwab app exactly
# Local: http://localhost:3000/api/auth/callback
# Production: https://your-netlify-site.netlify.app/api/auth/callback
SCHWAB_REDIRECT_URI=http://localhost:3000/api/auth/callback

# ─── Session Security ────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
SESSION_SECRET=replace_with_a_random_32_byte_base64_string

# ─── Anthropic Claude API ────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key

# ─── Netlify Blobs (auto-set in Netlify deployment, needed locally) ──────────
# NETLIFY_SITE_ID and NETLIFY_TOKEN are set automatically in Netlify CI.
# For local dev with blobs: run `netlify dev` instead of `npm run dev`
# NETLIFY_SITE_ID=your_site_id
# NETLIFY_TOKEN=your_netlify_personal_access_token

# ─── App Config ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
