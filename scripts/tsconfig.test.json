{
  "extends": "../tsconfig.json",
  "compilerOptions": {
    "module": "commonjs",
    "moduleResolution": "node",
    "target": "es2020",
    "outDir": "./dist",
    "rootDir": "..",
    "noEmit": false,
    "jsx": "preserve",
    "isolatedModules": false,
    "paths": {
      "@/*": ["../*"]
    },
    "skipLibCheck": true
  },
  "include": ["./test-engine-rules.ts", "../lib/signals/engine.ts", "../lib/signals/state.ts", "../lib/data/fund-metadata.ts", "../lib/schwab/types.ts"]
}
