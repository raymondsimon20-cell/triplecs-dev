{
  "extends": "../tsconfig.json",
  "compilerOptions": {
    "module": "commonjs",
    "moduleResolution": "node",
    "target": "es2020",
    "outDir": "./dist",
    "rootDir": "..",
    "noEmit": false,
    "jsx": "preserve",
    "isolatedModules": false,
    "paths": {
      "@/*": ["../*"]
    },
    "skipLibCheck": true
  },
  "include": [
    "./test-tier-classifier.ts",
    "../lib/signals/daily-plan.ts",
    "../lib/signals/engine.ts",
    "../lib/signals/state.ts",
    "../lib/signals/auto-config.ts",
    "../lib/data/fund-metadata.ts",
    "../lib/schwab/types.ts",
    "../lib/inbox.ts",
    "../lib/storage.ts"
  ]
}
