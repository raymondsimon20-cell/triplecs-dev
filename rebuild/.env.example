# Schwab API — HTTPS is REQUIRED end-to-end, including local dev tunnels.
# Plain HTTP breaks the OAuth callback. Use an https tunnel (e.g. ngrok) locally.
SCHWAB_CLIENT_ID=
SCHWAB_CLIENT_SECRET=
SCHWAB_REDIRECT_URI=https://your-domain/api/auth/callback

# Session
SESSION_SECRET= # 32+ char random string for JWT signing

# AI layer
ANTHROPIC_API_KEY=

# Email digest (optional)
DIGEST_EMAIL_TO=
RESEND_API_KEY=
